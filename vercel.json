{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/cron/overdue-invoices",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/stale-clients",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/calendar-poll",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/calendar-watch-renew",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/calendar-retry",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/data-retention",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/expire-quotes",
      "schedule": "15 4 * * *"
    },
    {
      "path": "/api/cron/recurring-invoices",
      "schedule": "0 5 * * *"
    }
  ]
}
