# Copy to .env.local and fill in real values. Never commit .env.local.

# --- Supabase ---
# From https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-only. Never expose to the browser. Used by lib/supabase/admin.ts.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Resend ---
# From https://resend.com/api-keys
RESEND_API_KEY=re_...
# Verified sender. Domain must be verified in Resend.
RESEND_FROM=ARBIQ <noreply@arbiq.cz>
# Internal notifications (BCC on lead/order emails). Comma-separated for multiple.
RESEND_BCC_ADMIN=bartolomej@arbiq.cz,fidelio@arbiq.cz
# Reply-To address for transactional emails.
RESEND_REPLY_TO=info@arbiq.cz

# --- OpenAI (AI chatbot) ---
OPENAI_API_KEY=sk-proj-...

# --- App ---
# Used in email links. No trailing slash.
APP_URL=http://localhost:3000

# --- Cron ---
# Random secret. Vercel Cron passes it as ?token=... to /api/cron/* routes.
CRON_SECRET=replace-with-32-random-bytes
